# You only need ONE of these keys for the project to work!
# Priority: OpenRouter → Groq → Gemini → OpenAI

# OpenRouter (Z.AI - Best reasoning, free tier available)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=<key>

# Google Gemini (Free tier available)
GEMINI_API_KEY=<key>


#hf token for open-source models (e.g. Llama-3, Falcon-40B, Mistral-7B-Instruct, etc.)
HUGGINGFACE_HUB_TOKEN=<key>
TAVILY_API_KEY=<key>
NVIDIA_API_KEY=<key>
